# === Soulseek Account ===
# Your Soulseek username and password (create at https://www.slsknet.org/)
SLSKD_SLSK_USERNAME=your_soulseek_username
SLSKD_SLSK_PASSWORD=your_soulseek_password

# === Spotify API ===
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# === slskd Settings ===
# Auto-generated by start.sh if left as default
SLSKD_API_KEY=supersecretapikey123change_me

# === Optional: Music directory to share on Soulseek ===
# Path to your local music library (shared with other Soulseek users)
# MUSIC_DIR=/path/to/your/music
